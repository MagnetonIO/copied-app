default_platform(:mac)

# Load .env at repo root (gitignored). Provides:
#   APP_STORE_CONNECT_API_KEY_ID
#   APP_STORE_CONNECT_API_ISSUER_ID
#   APP_STORE_CONNECT_API_KEY_PATH  (relative to repo root, e.g. .keys/AuthKey_XXX.p8)
require "dotenv"
Dotenv.load(File.expand_path("../.env", __dir__))

# App Store Connect API key auth. Uses the .p8 on disk — key never leaves the machine.
def asc_api_key
  key_id = ENV["APP_STORE_CONNECT_API_KEY_ID"]
  issuer_id = ENV["APP_STORE_CONNECT_API_ISSUER_ID"]
  key_path = ENV["APP_STORE_CONNECT_API_KEY_PATH"]
  return nil if key_id.nil? || issuer_id.nil? || key_path.nil?
  absolute_key_path = File.expand_path(key_path, File.expand_path("..", __dir__))
  return nil unless File.exist?(absolute_key_path)
  app_store_connect_api_key(
    key_id: key_id,
    issuer_id: issuer_id,
    key_filepath: absolute_key_path,
    in_house: false
  )
end

platform :mac do
  # ── CI ──────────────────────────────────────────────

  desc "Build unsigned for CI verification"
  lane :ci_build do
    xcodebuild(
      project: "Copied.xcodeproj",
      scheme: "CopiedMac",
      configuration: "Release",
      build: true,
      destination: "platform=macOS",
      xcargs: "CODE_SIGNING_ALLOWED=NO"
    )
    UI.success("CI build passed")
  end

  # ── Signed Build (dev) ──────────────────────────────

  desc "Build signed Release .app via xcodebuild archive (development signing)"
  lane :build_signed do |options|
    if ENV["CERTIFICATE_P12"]
      setup_ci_signing
    end

    build_mac_app(
      project: "Copied.xcodeproj",
      scheme: "CopiedMac",
      configuration: "Release",
      output_directory: "build/export",
      output_name: "Copied.app",
      export_method: "development",
      export_team_id: "7727LYTG96",
      skip_package_pkg: true,
      clean: true,
      destination: "generic/platform=macOS",
      export_options: {
        signingStyle: "automatic",
        teamID: "7727LYTG96"
      }
    )
  end

  # ── DMG ─────────────────────────────────────────────

  desc "Build signed .app and package into DMG"
  lane :build_dmg do
    build_signed

    app_path = "build/export/Copied.app"
    version = Time.now.strftime('%Y%m%d')
    dmg_name = "Copied-#{version}.dmg"
    dmg_path = "build/#{dmg_name}"

    sh("hdiutil create -volname 'Copied' -srcfolder '../#{app_path}' -ov -format UDZO '../#{dmg_path}'")

    UI.success("DMG created: #{dmg_path}")
    lane_context[:DMG_PATH] = dmg_path
    dmg_path
  end

  # ── Developer ID + Notarization (direct distribution) ─

  desc "Build with Developer ID signing and notarize for public distribution"
  lane :release do
    build_mac_app(
      project: "Copied.xcodeproj",
      scheme: "CopiedMac",
      configuration: "Release",
      output_directory: "build/release",
      output_name: "Copied.app",
      export_method: "developer-id",
      export_team_id: "7727LYTG96",
      skip_package_pkg: true,
      clean: true,
      destination: "generic/platform=macOS"
    )

    app_path = "build/release/Copied.app"

    if ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"]
      notarize(
        package: app_path,
        api_key_path: ENV["API_KEY_JSON_PATH"],
        print_log: true
      )
    end

    version = last_git_tag || Time.now.strftime('%Y%m%d')
    dmg_name = "Copied-#{version}.dmg"
    dmg_path = "build/#{dmg_name}"

    sh("hdiutil create -volname 'Copied' -srcfolder '../#{app_path}' -ov -format UDZO '../#{dmg_path}'")

    if ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"]
      notarize(
        package: "../#{dmg_path}",
        api_key_path: ENV["API_KEY_JSON_PATH"],
        print_log: true
      )
    end

    UI.success("Release DMG: #{dmg_path}")
    dmg_path
  end

  # ── Dual-variant build matrix ───────────────────────
  # The default build (Xcode Run / Archive) already produces the PAID variant because
  # project.yml sets SWIFT_ACTIVE_COMPILATION_CONDITIONS=MAS_BUILD at the target base.
  # These lanes wrap the two concrete distribution paths:
  #   • oss_build       — MAS_BUILD off, Developer ID + notarized DMG, LOCAL install only
  #   • paid_web_build  — MAS_BUILD on,  Developer ID + notarized DMG, website / GitHub
  # And existing `mas_build` covers the App Store submission path (MAS signing + pkg).

  desc "Build OSS variant (all features unlocked, MAS_BUILD off) → build/oss/ PKG. Auto-opens Installer at the end. Local-install use only; directory is gitignored."
  lane :oss_build do
    build_variant_pkg(
      variant_name: "oss",
      output_subdir: "build/oss",
      active_compilation_conditions: "",  # explicitly strip MAS_BUILD
      pkg_basename: "Copied-OSS",
      auto_open: true
    )
  end

  desc "Build PAID-LICENSE variant: MAS_BUILD + LICENSE_STRIPE on → build/license/ PKG. Stripe-backed paywall, Developer ID + notarized + stapled. Pass open:true to auto-open Installer (for local testing)."
  lane :paid_license_build do |options|
    build_variant_pkg(
      variant_name: "paid-license",
      output_subdir: "build/license",
      active_compilation_conditions: "MAS_BUILD LICENSE_STRIPE",
      pkg_basename: "Copied-License",
      auto_open: options[:open].to_s == "true"
    )
  end

  desc "Build PAID-LICENSE variant wired to localhost:3000 for end-to-end Stripe testing against the webhook-dev harness. Same Developer ID signing + notarization as paid_license_build so Gatekeeper accepts it; only difference is the compile-time Checkout URL."
  lane :paid_license_test_build do
    build_variant_pkg(
      variant_name: "paid-license-test",
      output_subdir: "build/license-test",
      active_compilation_conditions: "MAS_BUILD LICENSE_STRIPE LICENSE_STRIPE_LOCAL",
      pkg_basename: "Copied-License-TEST",
      auto_open: true
    )
  end

  # Shared implementation for .pkg outputs (OSS + paid-license). Same
  # archive+export path as build_variant, but wraps the .app in a productbuild
  # component pkg signed with the Developer ID Installer cert. Stapler staples
  # the notarization ticket so the pkg installs offline without prompts.
  def build_variant_pkg(variant_name:, output_subdir:, active_compilation_conditions:, pkg_basename:, auto_open: false)
    repo = File.expand_path("..", __dir__)
    sh("mkdir -p '#{repo}/#{output_subdir}'")

    version = read_marketing_version
    archive = "#{output_subdir}/Copied.xcarchive"
    cond = active_compilation_conditions.empty? ? "" : active_compilation_conditions

    sh(%(cd '#{repo}' && xcodebuild \\
      -project Copied.xcodeproj \\
      -scheme CopiedMac \\
      -configuration Release \\
      -destination 'generic/platform=macOS' \\
      -archivePath '#{archive}' \\
      DEVELOPMENT_TEAM=7727LYTG96 \\
      CODE_SIGN_STYLE=Automatic \\
      SWIFT_ACTIVE_COMPILATION_CONDITIONS="#{cond}" \\
      -allowProvisioningUpdates archive | tail -20))

    export_plist = "#{output_subdir}/ExportOptions-DevID.plist"
    File.write("#{repo}/#{export_plist}", developer_id_export_plist)
    sh(%(cd '#{repo}' && xcodebuild -exportArchive \\
      -archivePath '#{archive}' \\
      -exportPath '#{output_subdir}' \\
      -exportOptionsPlist '#{export_plist}' \\
      -allowProvisioningUpdates | tail -10))

    app_path = "#{output_subdir}/Copied.app"
    notarize_if_configured(app_path)

    pkg_path = "#{output_subdir}/#{pkg_basename}-v#{version}.pkg"
    component_pkg = "#{output_subdir}/Copied-component.pkg"
    installer_identity = "Developer ID Installer: Magneton Labs, LLC (7727LYTG96)"
    # Two-step: pkgbuild produces a component pkg that includes the postinstall
    # script (launches the app at end of install). productbuild wraps and signs
    # it as a distribution pkg Installer.app knows how to render.
    sh(%(pkgbuild \\
      --component '#{repo}/#{app_path}' \\
      --install-location /Applications \\
      --identifier com.mlong.copied.mac.installer \\
      --version #{version} \\
      --scripts '#{repo}/scripts/pkg-scripts' \\
      '#{repo}/#{component_pkg}'))
    sh(%(productbuild \\
      --package '#{repo}/#{component_pkg}' \\
      --sign '#{installer_identity}' \\
      '#{repo}/#{pkg_path}'))
    notarize_if_configured(pkg_path)
    sh("xcrun stapler staple '#{repo}/#{pkg_path}'") rescue UI.important("Stapler failed (OK if no API key configured)")

    UI.success("#{variant_name} build: #{pkg_path}")

    if auto_open
      UI.message("Opening Installer for #{pkg_path}...")
      sh("open '#{repo}/#{pkg_path}'")
    end
  end

  # Developer ID Application export plist (direct-distribution, not App Store).
  def developer_id_export_plist
    <<~PLIST
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
        <key>method</key><string>developer-id</string>
        <key>teamID</key><string>7727LYTG96</string>
        <key>signingStyle</key><string>automatic</string>
      </dict>
      </plist>
    PLIST
  end

  def read_marketing_version
    project_yml = File.read(File.expand_path("../project.yml", __dir__))
    m = project_yml.match(/MARKETING_VERSION:\s*"([^"]+)"/)
    m ? m[1] : "1.0.0"
  end

  # Notarize the given .app / .dmg / .pkg if an App Store Connect API key is configured.
  # Silent no-op when the key isn't present (so devs without credentials can still build).
  # For .pkg inputs fastlane can't infer the bundle id automatically, so we pass it.
  def notarize_if_configured(path, bundle_id: "com.mlong.copied.mac")
    return unless ENV["APP_STORE_CONNECT_API_KEY_ID"]
    key = asc_api_key
    return unless key
    opts = {
      package: path,
      api_key: key,
      print_log: true
    }
    opts[:bundle_id] = bundle_id if path.end_with?(".pkg")
    notarize(opts)
  end

  # ── Mac App Store ───────────────────────────────────
  # One-time setup is automated via `mas_setup` below. Only thing you still do by hand:
  #   1. App Store Connect API key at .keys/AuthKey_*.p8, referenced from .env
  #   2. App record "Copied App" created in App Store Connect (already done)
  # `mas_setup` creates:
  #   - "Apple Distribution" cert (signs the .app) if missing from Keychain
  #   - "Mac Installer Distribution" cert (signs the .pkg) if missing from Keychain
  #   - App Store provisioning profile bound to com.mlong.copied.mac with iCloud capability
  # CopiedMac-MAS.entitlements already present (app-sandbox + iCloud). Sandbox compatibility
  # still needs a local run to verify (CloudKit, menu bar, global hotkey).

  desc "Diagnose: list all App Store Connect app records"
  lane :list_apps do
    require "spaceship"
    repo = File.expand_path("..", __dir__)
    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      filepath: File.expand_path(ENV["APP_STORE_CONNECT_API_KEY_PATH"], repo)
    )
    Spaceship::ConnectAPI.token = token
    UI.header("App Store Connect apps")
    Spaceship::ConnectAPI::App.all.each do |a|
      UI.message "  #{a.bundle_id.ljust(40)} name=#{a.name.inspect} sku=#{a.sku.inspect}"
    end
  end

  desc "Diagnose: list all Bundle IDs registered in Apple Developer Portal for this team"
  lane :list_bundle_ids do
    require "spaceship"
    repo = File.expand_path("..", __dir__)
    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      filepath: File.expand_path(ENV["APP_STORE_CONNECT_API_KEY_PATH"], repo)
    )
    Spaceship::ConnectAPI.token = token
    UI.header("Bundle IDs in Developer Portal")
    Spaceship::ConnectAPI::BundleId.all.each do |b|
      UI.message "  #{b.identifier.ljust(40)} platform=#{b.platform.inspect} name=#{b.name.inspect}"
    end
  end

  desc "Register com.mlong.copied.mac as a macOS Bundle ID in Developer Portal if missing"
  lane :register_mac_bundle_id do
    require "spaceship"
    repo = File.expand_path("..", __dir__)
    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      filepath: File.expand_path(ENV["APP_STORE_CONNECT_API_KEY_PATH"], repo)
    )
    Spaceship::ConnectAPI.token = token
    identifier = "com.mlong.copied.mac"
    existing = Spaceship::ConnectAPI::BundleId.find(identifier)
    if existing
      UI.success("Bundle ID #{identifier} already registered — platform=#{existing.platform.inspect}, seed_id=#{existing.seed_id.inspect}")
    else
      UI.message("Creating Bundle ID #{identifier} for macOS...")
      created = Spaceship::ConnectAPI::BundleId.create(
        name: "Copied App",
        identifier: identifier,
        platform: "MAC_OS"
      )
      UI.success("Created Bundle ID #{created.identifier}")
    end
  end

  # App Store Connect app record creation is manual (fastlane's create_app_online
  # only supports Apple-ID+2FA auth, not JWT API keys as of fastlane 2.231.1).
  # Create at https://appstoreconnect.apple.com/apps → + → New App:
  #   Platform: macOS, Name: Copied App, Bundle ID: com.mlong.copied.mac,
  #   SKU: com.mlong.copied.mac, Language: English (U.S.).

  desc "One-time: create MAS cert + installer cert + provisioning profile via API"
  lane :mas_setup do
    key = asc_api_key
    UI.user_error!("Missing App Store Connect API key. Check .env + .keys/AuthKey_*.p8") unless key

    UI.header("Fetching/creating Apple Distribution cert")
    get_certificates(
      api_key: key,
      platform: "macos",
      generate_apple_certs: true,
      output_path: "./.keys"
    )
    app_cert_id = lane_context[SharedValues::CERT_CERTIFICATE_ID]

    UI.header("Fetching/creating Mac Installer Distribution cert")
    get_certificates(
      api_key: key,
      platform: "macos",
      type: "mac_installer_distribution",
      output_path: "./.keys"
    )

    UI.header("Fetching/creating Mac App Store provisioning profile")
    # For macOS, the default (no adhoc/developer_id/development flag) is Mac App Store.
    # cert_id pins the profile to the Apple Distribution cert we just fetched —
    # without it sigh looks for the legacy "3rd Party Mac Developer Application".
    get_provisioning_profile(
      api_key: key,
      platform: "macos",
      app_identifier: "com.mlong.copied.mac",
      provisioning_name: "Copied Mac MAS",
      cert_id: app_cert_id,
      output_path: "./.keys"
    )

    UI.success("MAS setup complete. Certs are in Keychain; profile at .keys/Copied_Mac_MAS.provisionprofile (also installed).")
  end

  desc "Build sandboxed .app with Apple Development signing so it can LAUNCH locally — use this to test sandbox compatibility before the real MAS build"
  lane :mas_debug_build do
    repo = File.expand_path("..", __dir__)
    sh("mkdir -p '#{repo}/build/mas-debug'")

    UI.header("Archiving with MAS entitlements + Apple Development signing (local-run)")
    archive_path = "build/mas-debug/Copied.xcarchive"
    sh(%(cd '#{repo}' && xcodebuild -project Copied.xcodeproj -scheme CopiedMac -configuration Debug -destination 'generic/platform=macOS' -archivePath '#{archive_path}' DEVELOPMENT_TEAM=7727LYTG96 CODE_SIGN_STYLE=Automatic CODE_SIGN_ENTITLEMENTS=CopiedMac/CopiedMac-MAS.entitlements SWIFT_ACTIVE_COMPILATION_CONDITIONS='DEBUG MAS_BUILD MAS_STOREFRONT' -allowProvisioningUpdates archive | tail -20))

    app_in_archive = "#{repo}/#{archive_path}/Products/Applications/Copied.app"
    sh("rm -rf '#{repo}/build/mas-debug/Copied.app' && cp -R '#{app_in_archive}' '#{repo}/build/mas-debug/Copied.app'")
    UI.success("Sandboxed debug build: build/mas-debug/Copied.app — launch with `open` to test under sandbox")
  end

  desc "Build signed MAS .pkg ready for Transporter/upload"
  lane :mas_build do |options|
    # Uses direct xcodebuild rather than gym because gym mis-detects the default scheme
    # when the project has no on-disk .xcscheme files (XcodeGen materializes them lazily).
    # Mirrors scripts/build-release.sh for the archive/export shape.
    repo = File.expand_path("..", __dir__)
    sh("mkdir -p '#{repo}/build/mas'")

    UI.header("Archiving with MAS entitlements + Apple Distribution signing")
    archive_path = "build/mas/Copied.xcarchive"
    sh(%(cd '#{repo}' && xcodebuild -project Copied.xcodeproj -scheme CopiedMac -configuration Release -destination 'generic/platform=macOS' -archivePath '#{archive_path}' DEVELOPMENT_TEAM=7727LYTG96 CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY='Apple Distribution' PROVISIONING_PROFILE_SPECIFIER='Copied Mac MAS' CODE_SIGN_ENTITLEMENTS=CopiedMac/CopiedMac-MAS.entitlements SWIFT_ACTIVE_COMPILATION_CONDITIONS='MAS_BUILD MAS_STOREFRONT' -allowProvisioningUpdates archive | tail -40))

    UI.header("Exporting .pkg for App Store submission")
    export_plist = "build/mas/ExportOptions-MAS.plist"
    File.write("#{repo}/#{export_plist}", <<~PLIST)
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
          <key>method</key><string>app-store</string>
          <key>signingStyle</key><string>manual</string>
          <key>signingCertificate</key><string>Apple Distribution</string>
          <key>installerSigningCertificate</key><string>3rd Party Mac Developer Installer</string>
          <key>provisioningProfiles</key>
          <dict>
              <key>com.mlong.copied.mac</key><string>Copied Mac MAS</string>
          </dict>
          <key>teamID</key><string>7727LYTG96</string>
      </dict>
      </plist>
    PLIST

    sh(%(cd '#{repo}' && xcodebuild -exportArchive -archivePath '#{archive_path}' -exportPath build/mas -exportOptionsPlist '#{export_plist}' -allowProvisioningUpdates | tail -10))

    pkg_path = "build/mas/Copied.pkg"
    UI.user_error!("MAS build failed — no .pkg at #{pkg_path}") unless File.exist?("#{repo}/#{pkg_path}")
    UI.success("MAS build complete: #{pkg_path}")

    # Optional auto-open for local testing — MAS pkgs install to a sandboxed
    # app via Installer.app, same as any other distribution pkg.
    if options[:open].to_s == "true"
      UI.message("Opening Installer for #{pkg_path}...")
      sh("open '#{repo}/#{pkg_path}'")
    end
  end

  desc "Upload current MAS .pkg to TestFlight"
  lane :testflight do
    mas_build unless File.exist?("../build/mas/Copied.pkg")
    key = asc_api_key
    UI.user_error!("Missing App Store Connect API key (fastlane/api_key.json)") unless key

    upload_to_testflight(
      api_key: key,
      pkg: "build/mas/Copied.pkg",
      skip_waiting_for_build_processing: true
    )
  end

  desc "Upload metadata + screenshots only (no build, no submit)"
  lane :upload_metadata do
    key = asc_api_key
    UI.user_error!("Missing App Store Connect API key (fastlane/api_key.json)") unless key

    upload_to_app_store(
      api_key: key,
      platform: "osx",
      skip_binary_upload: true,
      skip_screenshots: false,
      skip_metadata: false,
      force: true,
      precheck_include_in_app_purchases: false,
      submit_for_review: false
    )
  end

  desc "Upload screenshots only"
  lane :upload_screenshots do
    key = asc_api_key
    UI.user_error!("Missing App Store Connect API key (fastlane/api_key.json)") unless key

    upload_to_app_store(
      api_key: key,
      platform: "osx",
      skip_binary_upload: true,
      skip_screenshots: false,
      skip_metadata: true,
      force: true,
      submit_for_review: false
    )
  end

  desc "MAS build + upload binary + upload metadata, but DO NOT submit for review. Use this to stage a build in App Store Connect for manual submit via the web UI."
  lane :mas_upload do
    key = asc_api_key
    UI.user_error!("Missing App Store Connect API key (fastlane/api_key.json)") unless key

    mas_build unless File.exist?("../build/mas/Copied.pkg")

    upload_to_app_store(
      api_key: key,
      platform: "osx",
      pkg: "build/mas/Copied.pkg",
      skip_binary_upload: false,
      skip_screenshots: false,
      skip_metadata: false,
      force: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      submit_for_review: false,
      automatic_release: false
    )

    UI.success("Uploaded Copied App 1.2.0 to App Store Connect (NOT submitted). Review + submit at https://appstoreconnect.apple.com/apps")
  end

  desc "Submit the already-uploaded build for Apple review. Use this after mas_upload has pushed a binary to App Store Connect and you've verified metadata/icon/categories in the web UI. Does NOT rebuild or re-upload."
  lane :mas_submit do
    key = asc_api_key
    UI.user_error!("Missing App Store Connect API key (fastlane/api_key.json)") unless key

    upload_to_app_store(
      api_key: key,
      platform: "osx",
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: true,
      force: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      submit_for_review: true,
      automatic_release: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false
      }
    )

    UI.success("Submitted Copied App for App Review")
  end

  desc "Full release: MAS build + upload + metadata + submit for review"
  lane :mas_release do
    key = asc_api_key
    UI.user_error!("Missing App Store Connect API key (fastlane/api_key.json)") unless key

    mas_build

    upload_to_app_store(
      api_key: key,
      platform: "osx",
      pkg: "build/mas/Copied.pkg",
      skip_screenshots: false,
      skip_metadata: false,
      force: true,
      precheck_include_in_app_purchases: false,
      submit_for_review: true,
      automatic_release: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false
      }
    )

    UI.success("Submitted Copied App to App Review")
  end

  desc "Helper for creating a sandbox tester — opens the App Store Connect page and prints suggested credentials + step-by-step instructions for using the tester in the purchase sheet. Apple's API does NOT expose sandbox tester CRUD (as of fastlane 2.231.1 / Apple API Jun 2026), so creation is manual web-UI only."
  lane :create_sandbox_tester do |options|
    require "securerandom"
    require "open3"

    email = options[:email] || "copied-sandbox+#{Time.now.to_i}@getcopied.app"
    password = options[:password] || (SecureRandom.alphanumeric(10) + "Aa1!")
    sandbox_url = "https://appstoreconnect.apple.com/access/users/sandbox"

    UI.header "Sandbox Tester creation (manual web UI)"
    UI.important "Apple's App Store Connect API doesn't expose sandbox tester CRUD."
    UI.important "Both GET and POST /v1/sandboxTesters return 404 — this must be done in the web UI."
    UI.message ""
    UI.message "Opening #{sandbox_url}"
    UI.message ""
    UI.message "Suggested credentials (copy to your password manager NOW):"
    UI.message ""
    UI.message "  Email:             #{email}"
    UI.message "  Password:          #{password}"
    UI.message "  First Name:        Copied"
    UI.message "  Last Name:         Tester"
    UI.message "  App Store Country: United States"
    UI.message "  Date of Birth:     01 / 01 / 1990"
    UI.message "  Secret Question:   Favorite color"
    UI.message "  Secret Answer:     blue"
    UI.message ""
    UI.message "Steps on the page that just opened:"
    UI.message "  1. Click the \"+\" button top-right of the Testers table"
    UI.message "  2. Fill the form with the values above"
    UI.message "  3. Click \"Invite\". Apple sends a verification email if the domain"
    UI.message "     is deliverable; sandbox testers usually sign in on the purchase"
    UI.message "     sheet without verifying for test purchases."
    UI.message ""
    UI.message "Then, to run the real purchase flow in Copied (Dev):"
    UI.message "  4. System Settings → Apple ID → Media & Purchases → Sign Out"
    UI.message "     (sign out the App Store Apple ID only; leave iCloud signed in)"
    UI.message "  5. Launch Copied (Dev) → ⌘, → Sync tab → \"Unlock iCloud Sync\""
    UI.message "  6. Purchase sheet prompts for Apple ID. Enter the sandbox"
    UI.message "     email/password above. Touch ID or password confirms."
    UI.message "  7. Purchase completes → iCloudSyncPurchased flag flips → restart"
    UI.message "     prompt → confirm → sync activates on next launch."
    UI.message ""

    Open3.popen3("pbcopy") { |stdin, _, _| stdin.write(email) }
    UI.success "📋 Email copied to clipboard: #{email}"
    UI.success "🔐 Password: #{password} (save this — clipboard will be overwritten later)"

    system("open", sandbox_url)
  end

  desc "(broken — Apple API returns 404) List existing sandbox testers. Falls back to opening the web UI."
  lane :list_sandbox_testers do
    sandbox_url = "https://appstoreconnect.apple.com/access/users/sandbox"
    UI.important "Apple's API doesn't expose sandbox tester listing. Opening web UI instead."
    system("open", sandbox_url)
  end

  # ── Helpers ─────────────────────────────────────────

  private_lane :setup_ci_signing do
    keychain_name = "ci-signing"
    keychain_password = ""

    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: true,
      unlock: true,
      timeout: 3600
    )

    import_certificate(
      certificate_path: "ci_certificate.p12",
      certificate_password: ENV["CERTIFICATE_PASSWORD"],
      keychain_name: keychain_name,
      keychain_password: keychain_password
    )

    install_provisioning_profile(path: "ci_profile.provisionprofile")
  end
end

platform :ios do
  desc "Unsigned iOS Simulator build of CopiedIOS → build/ios-sim/Copied.app"
  lane :dev_build do
    repo = File.expand_path("..", __dir__)
    sh("mkdir -p '#{repo}/build/ios-sim'")

    # Regenerate the Xcode project in case project.yml changed.
    sh("cd '#{repo}' && xcodegen generate")

    UI.header("xcodebuild — iOS Simulator (ad-hoc signed so entitlements ship)")
    derived = "#{repo}/build/ios-sim/DerivedData"
    # Ad-hoc sign (CODE_SIGN_IDENTITY="-") rather than CODE_SIGNING_ALLOWED=NO,
    # because the latter skips the entire entitlements step — which silently
    # breaks App Groups and App Extension communication on the Simulator.
    sh(%(cd '#{repo}' && xcodebuild \
      -project Copied.xcodeproj \
      -scheme CopiedIOS \
      -configuration Debug \
      -destination 'generic/platform=iOS Simulator' \
      -derivedDataPath '#{derived}' \
      CODE_SIGN_IDENTITY="-" \
      CODE_SIGN_STYLE=Manual \
      DEVELOPMENT_TEAM="" \
      CODE_SIGNING_REQUIRED=NO \
      build | tail -20))

    built_app = "#{derived}/Build/Products/Debug-iphonesimulator/Copied.app"
    UI.user_error!("iOS Simulator build failed — no app at #{built_app}") unless File.directory?(built_app)

    sh("rm -rf '#{repo}/build/ios-sim/Copied.app' && cp -R '#{built_app}' '#{repo}/build/ios-sim/Copied.app'")
    UI.success("iOS Simulator build: build/ios-sim/Copied.app")
    UI.message("Install + launch: ./scripts/ios-sim.sh run")
  end

  desc "Signed App Store archive → build/ios/Copied.ipa"
  lane :archive do
    repo = File.expand_path("..", __dir__)
    sh("mkdir -p '#{repo}/build/ios'")
    sh("cd '#{repo}' && xcodegen generate")

    UI.header("Archiving CopiedIOS with Apple Distribution signing")
    archive_path = "build/ios/Copied.xcarchive"
    sh(%(cd '#{repo}' && xcodebuild \
      -project Copied.xcodeproj \
      -scheme CopiedIOS \
      -configuration Release \
      -destination 'generic/platform=iOS' \
      -archivePath '#{archive_path}' \
      DEVELOPMENT_TEAM=7727LYTG96 \
      CODE_SIGN_STYLE=Automatic \
      SWIFT_ACTIVE_COMPILATION_CONDITIONS='MAS_BUILD MAS_STOREFRONT' \
      -allowProvisioningUpdates \
      archive | tail -40))

    UI.header("Exporting .ipa for App Store")
    export_plist = "build/ios/ExportOptions.plist"
    File.write("#{repo}/#{export_plist}", <<~PLIST)
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
          <key>method</key><string>app-store</string>
          <key>signingStyle</key><string>automatic</string>
          <key>teamID</key><string>7727LYTG96</string>
      </dict>
      </plist>
    PLIST

    sh(%(cd '#{repo}' && xcodebuild -exportArchive \
      -archivePath '#{archive_path}' \
      -exportPath build/ios \
      -exportOptionsPlist '#{export_plist}' \
      -allowProvisioningUpdates | tail -10))

    ipa_path = "build/ios/Copied.ipa"
    UI.user_error!("iOS archive failed — no .ipa at #{ipa_path}") unless File.exist?("#{repo}/#{ipa_path}")
    UI.success("iOS archive: #{ipa_path}")
  end

  desc "Upload existing build/ios/Copied.ipa to TestFlight (no auto-submit)"
  lane :testflight do
    # Does not re-archive: the caller (scripts/build.sh ios-testflight) is
    # responsible for running `bump-build.sh` then `archive` so the IPA here
    # always reflects the current build number. Caching the archive and
    # silently uploading stale bits is the wrong default.
    ipa = "build/ios/Copied.ipa"
    UI.user_error!("No IPA at #{ipa} — run `fastlane ios archive` (or `./scripts/build.sh ios-testflight`) first") unless File.exist?("../#{ipa}")

    key = asc_api_key
    UI.user_error!("Missing App Store Connect API key — set APP_STORE_CONNECT_API_KEY_ID/_ISSUER_ID/_PATH in .env") unless key

    upload_to_testflight(
      api_key: key,
      ipa: ipa,
      skip_submission: true,
      skip_waiting_for_build_processing: true
    )
    UI.success("Uploaded to TestFlight. Check App Store Connect for processing status.")
  end
end
