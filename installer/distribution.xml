<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Copied</title>
    <welcome file="welcome.html" mime-type="text/html"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>
    <options
        customize="never"
        require-scripts="false"
        hostArchitectures="arm64,x86_64"/>
    <domains enable_anywhere="false"
             enable_currentUserHome="false"
             enable_localSystem="true"/>
    <choices-outline>
        <line choice="default">
            <line choice="com.mlong.copied.mac.pkg"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="com.mlong.copied.mac.pkg" visible="false">
        <pkg-ref id="com.mlong.copied.mac.pkg"/>
    </choice>
    <pkg-ref id="com.mlong.copied.mac.pkg"
             version="0"
             onConclusion="none">Copied-component.pkg</pkg-ref>
</installer-gui-script>
