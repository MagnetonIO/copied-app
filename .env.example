# Copy to .env and fill in your real values (both gitignored).
# Generate a key at App Store Connect → Users and Access → Integrations → Keys.
APP_STORE_CONNECT_API_KEY_ID=YOUR_10_CHAR_KEY_ID
APP_STORE_CONNECT_API_ISSUER_ID=00000000-0000-0000-0000-000000000000
APP_STORE_CONNECT_API_KEY_PATH=.keys/AuthKey_YOUR_KEY_ID.p8
